generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id                   String     @id @default(cuid())
  email                String     @unique
  passwordHash         String
  name                 String
  role                 AdminRole  @default(ADMIN)
  lastLoginAt          DateTime?
  loginAttempts        Int        @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  auditLogs            AuditLog[]

  @@map("admin_users")
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  featured        Boolean       @default(false)
  published       Boolean       @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  categoryId      String?
  authorId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String
  tags            BlogPostTag[]
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  author          TeamMember?   @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  color       String?
  orderIndex  Int        @default(0)
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  blogPosts   BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  blogPosts   BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  id         String   @id @default(cuid())
  blogPostId String
  blogTagId  String
  createdAt  DateTime @default(now())
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogTag    BlogTag  @relation(fields: [blogTagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, blogTagId])
  @@map("blog_post_tags")
}

model FAQ {
  id         String   @id @default(cuid())
  question   String
  answer     String
  category   String?
  orderIndex Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faqs")
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  title       String
  bio         String?
  photoUrl    String?
  email       String?
  phone       String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Doctor-specific fields
  isDoctor    Boolean  @default(false)
  credentials String?
  experience  String?
  education   String[]
  certifications String[]
  languages   String[]
  doctor      Doctor?
  blogPosts   BlogPost[]

  @@map("team_members")
}

model Doctor {
  id                    String   @id @default(cuid())
  teamMemberId          String   @unique
  professionalBio       String   @db.Text
  medicalSchool         String?
  graduationYear        Int?
  residency             String?
  fellowship            String?
  boardCertifications   String[]
  hospitalAffiliations  String[]
  researchInterests     String[]
  publications          String[]
  awards                String[]
  memberships           String[]
  consultationFee       String?
  availability          String?
  emergencyContact      String?
  bookingUrl            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  teamMember            TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@map("doctors")
}

model AuditLog {
  id         String     @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime   @default(now())
  user       AdminUser? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  features    String[]
  icon        String?
  imageUrl    String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UninsuredService {
  id          String   @id @default(cuid())
  category    String   // "clinical", "work_educational_government", "insurance_admin"
  title       String
  description String?
  price       String   // e.g. "$180", "$40 (1-4 lesions, additional: $5 each)"
  isInsured   Boolean  @default(false) // For items that are noted as insured
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("uninsured_services")
}

model ClinicLocation {
  id            String   @id @default(cuid())
  name          String
  address       String
  phone         String?
  fax           String?
  hours         String?
  mapsQuery     String?
  orderIndex    Int      @default(0)
  isPrimary     Boolean  @default(false)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("clinic_locations")
}

model SystemSettings {
  id                   String   @id @default(cuid())
  primaryPhone         String
  emergencyPhone       String?
  faxNumber            String?
  adminEmail           String
  businessHours        String
  timezone             String   @default("America/Toronto")
  dateFormat           String   @default("MM/DD/YYYY")

  sessionTimeout       Int      @default(30)
  maxLoginAttempts     Int      @default(5)
  passwordExpiry       Int      @default(90)

  ipWhitelist          String?
  homepageImageUrl     String?
  appointmentBookingUrl String?
  patientIntakeUrl     String?
  whyChooseUsImageUrl  String?
  aboutMissionImageUrl String?
  servicesPaymentImageUrl String?
  
  // Practice status
  acceptingNewPatients Boolean  @default(true)
  
  // Announcement settings
  announcementEnabled  Boolean  @default(false)
  announcementTitle    String?
  announcementMessage  String?
  announcementType     String   @default("info") // info, warning, error, success
  announcementDisplay  String   @default("banner") // banner, popup, both
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  updatedBy            String?
  address              String   @default("Unit 216, 1980 Ogilvie Road, Gloucester, Ottawa, K1J 9L3")

  @@map("system_settings")
}


enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}


enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  DELAYED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}
